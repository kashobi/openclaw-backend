class TranscriptProvider:
    """Interface. Implement fetch() and set `is_live`.

    Deliberately abstract: real-time transcript feeds cost $1k-10k/month and are not wired here.
    The day one is paid for, it drops in behind this interface and nothing else changes.
    """
    name = "none"
    is_live = False

    def fetch(self, symbol, year=None, quarter=None):
        return None


class FMPTranscriptProvider(TranscriptProvider):
    """Post-call transcript. Available hours after the call ends, not during it.

    NOT live. The UI must never claim otherwise -- telling a user they are reading a call in
    real time when they are reading it four hours late is exactly the kind of small lie that
    destroys trust in a research product.
    """
    name = "fmp"
    is_live = False

    def __init__(self, key):
        self.key = key

    def fetch(self, symbol, year=None, quarter=None):
        if not self.key:
            return None
        try:
            params = {"apikey": self.key}
            if year:
                params["year"] = year
            if quarter:
                params["quarter"] = quarter
            r = requests.get(FMP_BASE + "/api/v3/earning_call_transcript/" + symbol.upper(),
                             params=params, timeout=25)
            if r.status_code != 200:
                return None
            data = r.json() or []
            if isinstance(data, list) and data:
                d = data[0]
                return {"text": d.get("content") or "", "date": d.get("date"),
                        "source": "fmp", "is_live": False}
        except Exception as e:
            logger.warning("fmp transcript %s: %s", symbol, e)
        return None


def get_transcript_provider():
    """Returns the best provider available. FMP today; a live feed the day it is paid for."""
    live = os.environ.get("LIVE_TRANSCRIPT_PROVIDER", "").strip()
    if live:
        logger.info("live transcript provider configured: %s (not implemented -- add the class)", live)
    return FMPTranscriptProvider(os.environ.get("FMP_KEY", "").strip())


# =========================================================================== #
# 4. NLP ANALYZER  —  tone, themes, Q&A pressure
#
# The LLM is used ONLY where being approximately right is acceptable: tone,
# themes, how hard analysts pushed. The NUMBERS come from regex, because a model
# that hallucinates an EPS figure is worse than no figure at all.
# =========================================================================== #

TONE_PROMPT = """You are analyzing an earnings call transcript for a retail investor.

Return ONLY valid JSON, no markdown, no preamble:
{
  "tone": <float -1.0 to 1.0; -1 = defensive/evasive, 0 = neutral, 1 = confident/expansive>,
  "tone_reason": "<one sentence on WHY, quoting nothing verbatim>",
  "qa_pressure": <float 0.0 to 1.0; how hard analysts pushed on weak points>,
  "qa_reason": "<one sentence: what analysts kept returning to>",
  "themes": ["<3-5 short phrases management repeated most>"],
  "guidance_signal": "<raised|lowered|reaffirmed|none>",
  "margin_signal": "<expanding|compressing|stable|unclear>",
  "hedging": <float 0.0 to 1.0; how much management hedged or deflected>
}

Rules:
- Judge tone from HOW things are said, not whether the numbers were good.
- qa_pressure is high when analysts repeatedly circle the same soft spot, or when
  management answers a question that was not asked.
- Do not quote the transcript. Paraphrase.
- If the transcript is too short or missing, return nulls rather than guessing.

TRANSCRIPT:
"""


def analyze_transcript(text, llm_fn):
    """llm_fn(prompt) -> str. Returns the parsed dict, or a null-filled dict on any failure.

    Fails to NULL, never to a made-up number. A confident wrong tone score is worse than an
    honest 'we could not read the call'.
    """
    empty = {"tone": None, "tone_reason": None, "qa_pressure": None, "qa_reason": None,
             "themes": [], "guidance_signal": "none", "margin_signal": "unclear", "hedging": None}
    if not text or len(text) < 800 or not llm_fn:
        return empty
    try:
        body = re.sub(r"\s+", " ", text)[:45000]
        raw = llm_fn(TONE_PROMPT + body)
        if not raw:
            return empty
        clean = re.sub(r"^```(?:json)?|```$", "", str(raw).strip(), flags=re.M).strip()
        d = json.loads(clean)
        out = dict(empty)
        out.update({k: d.get(k, empty[k]) for k in empty})
        for k in ("tone", "qa_pressure", "hedging"):
            try:
                out[k] = float(out[k]) if out[k] is not None else None
            except Exception:
                out[k] = None
        return out
    except Exception as e:
        logger.warning("analyze_transcript: %s", e)
        return empty


# =========================================================================== #
# 5. EARNINGS EVENT SCORE
#
# Bounded 0-100. It is a FACTOR, not a verdict. It does not override the engine,
# for the same reason convergence does not: it has never been validated. Every
# event is logged so that in a few quarters the data can say whether it should.
# =========================================================================== #

def score_event(ev):
    """0-100 plus the reasoning. Guidance is weighted hardest, on purpose.

    The single most reliable regularity in earnings reactions is that the market trades the
    FUTURE, not the quarter. A great quarter with cut guidance sells off; a poor quarter with
    raised guidance rallies. Weighting the backward-looking beat above the forward-looking
    guidance would get the sign wrong on the most common confusing case there is.
    """
    pts, why = 50, []

    eps_s = ev.get("eps_surprise_pct")
    rev_s = ev.get("rev_surprise_pct")
    guide = ev.get("guidance_direction") or "none"
    tone = ev.get("mgmt_tone")
    qa = ev.get("qa_pressure")
    margin = ev.get("margin_direction")

    # --- Guidance: the heaviest weight, because it is what the market actually trades. ---
    if guide == "raised":
        pts += 20; why.append("guidance raised -- management is telling you the next quarter is better than the street thinks")
    elif guide == "lowered":
        pts -= 22; why.append("guidance lowered -- this usually matters more than the quarter that just closed")
    elif guide == "reaffirmed":
        pts += 3; why.append("guidance reaffirmed")

    # --- The quarter itself. Real, but backward-looking. ---
    if eps_s is not None:
        if eps_s >= 10:
            pts += 12; why.append("EPS beat by %.0f%%" % eps_s)
        elif eps_s > 0:
            pts += 6; why.append("EPS beat by %.1f%%" % eps_s)
        elif eps_s > -5:
            pts -= 6; why.append("EPS missed by %.1f%%" % abs(eps_s))
        else:
            pts -= 14; why.append("EPS missed badly, by %.0f%%" % abs(eps_s))

    if rev_s is not None:
        # Revenue is harder to manage than EPS -- you cannot buy back your way to a revenue beat.
        if rev_s >= 3:
            pts += 10; why.append("revenue beat by %.1f%% (harder to engineer than an EPS beat)" % rev_s)
        elif rev_s > 0:
            pts += 5
        elif rev_s > -3:
            pts -= 6; why.append("revenue light by %.1f%%" % abs(rev_s))
        else:
            pts -= 12; why.append("revenue missed by %.0f%% -- demand, not accounting" % abs(rev_s))

    if margin == "expanding":
        pts += 6; why.append("margins expanding")
    elif margin == "compressing":
        pts -= 8; why.append("margins compressing -- costs are outrunning pricing power")

    if tone is not None:
        pts += int(tone * 6)
        if tone <= -0.4:
            why.append("management sounded defensive")
        elif tone >= 0.5:
            why.append("management sounded confident")

    if qa is not None and qa >= 0.6:
        pts -= 6
        why.append("analysts pushed hard on a soft spot and kept coming back to it")

    return {"event_score": max(0, min(100, int(pts))), "event_note": "; ".join(why[:6])}


# =========================================================================== #
# 6. PLAIN-ENGLISH EXPLAINER
#
# The actual product. Anyone can show you an EPS number. The question a retail
# investor actually has is: "it beat -- why is it DOWN?"
#
# CAUSATION RULE: we do not know why a stock moved. We rank the plausible
# readings by evidence and say which is most likely. Every sentence is phrased
# accordingly. A research product that claims to know causation is lying, and if
# you hold a license, it is lying on the record.
# =========================================================================== #

def classify_divergence(ev):
    """Name the case. This is what the user is actually confused about."""
    eps_s = ev.get("eps_surprise_pct")
    rev_s = ev.get("rev_surprise_pct")
    react = ev.get("reaction_1d_pct")
    guide = ev.get("guidance_direction") or "none"

    beat = (eps_s is not None and eps_s > 0) and (rev_s is None or rev_s > -1)
    miss = (eps_s is not None and eps_s <= 0) or (rev_s is not None and rev_s < -1)
    up = react is not None and react > 1
    down = react is not None and react < -1

    if beat and down:
        return "beat_down"
    if miss and up:
        return "miss_up"
    if beat and guide == "lowered":
        return "good_qtr_weak_guide"
    if miss and guide == "raised":
        return "weak_qtr_better_guide"
    if beat and up:
        return "beat_up"
    if miss and down:
        return "miss_down"
    return "mixed"


def explain_event(ev):
    """The four questions a retail investor actually asks, answered in plain English."""
    d = classify_divergence(ev)
    eps_s = ev.get("eps_surprise_pct")
    rev_s = ev.get("rev_surprise_pct")
    react = ev.get("reaction_1d_pct")
    guide = ev.get("guidance_direction") or "none"
    margin = ev.get("margin_direction")
    tone = ev.get("mgmt_tone")
    qa = ev.get("qa_pressure")
    sym = ev.get("symbol", "the stock")

    # --- What happened ---
    bits = []
    if eps_s is not None:
        bits.append("EPS came in %s expectations by %.1f%%" %
                    ("above" if eps_s > 0 else "below", abs(eps_s)))
    if rev_s is not None:
        bits.append("revenue was %s by %.1f%%" %
                    ("ahead" if rev_s > 0 else "light", abs(rev_s)))
    if guide != "none":
        bits.append("guidance was %s" % guide)
    what = ". ".join([b[0].upper() + b[1:] for b in bits]) + "." if bits else \
        "The release is in, but the numbers could not be parsed cleanly."

    # --- What management said ---
    said = []
    if tone is not None:
        said.append("Management sounded %s on the call." %
                    ("confident" if tone >= 0.4 else
                     "defensive" if tone <= -0.4 else "measured"))
    if margin:
        said.append("They pointed to margins %s." % margin)
    if qa is not None and qa >= 0.6:
        said.append("Analysts pushed hard on one area and kept returning to it, which usually "
                    "means the street is not satisfied with the answer.")
    if not said:
        said.append("We do not have the call transcript for this quarter yet, so there is nothing "
                    "to say about what management said. We will not guess.")

    # --- Why the stock moved. RANKED READINGS, NOT ASSERTED CAUSE. ---
    reasons = {
        "beat_down": (
            "%s beat and still fell. The most likely reading, in order: the guidance was %s, and the "
            "market trades the future rather than the quarter that just closed. %s Expectations may "
            "also have run ahead of the published estimate -- the number traders had in their heads "
            "(the 'whisper') is often higher than the one on the screen, and a beat against the "
            "screen can still be a miss against the room."
            % (sym,
               guide if guide != "none" else "not raised",
               "Margins were described as compressing, which means the profit is being bought with "
               "costs. " if margin == "compressing" else "")),
        "miss_up": (
            "%s missed and still rose. The most likely reading: the miss was smaller than feared, or "
            "the outlook improved. %s When a stock rallies on bad numbers, the news was usually "
            "already in the price -- the sellers had already sold."
            % (sym, "Guidance was raised, which is the strongest version of that story. "
               if guide == "raised" else "")),
        "good_qtr_weak_guide": (
            "This is the classic trap. The quarter was fine; the OUTLOOK was cut. Markets pay for "
            "future cash flows, not past ones, so a lowered forecast can outweigh a good quarter "
            "entirely. When you see a green quarter and a red stock, look at the guidance first."),
        "weak_qtr_better_guide": (
            "The quarter was weak but the outlook improved. Investors will often forgive one bad "
            "quarter if management convinces them it was the bottom. Whether they are right is the "
            "open question -- 'the worst is behind us' is the most-repeated sentence in earnings."),
        "beat_up": (
            "Beat, and the stock rose. The simple case: the numbers were better than expected and "
            "the outlook did not undercut them."),
        "miss_down": (
            "Missed, and the stock fell. The simple case. %s"
            % ("Guidance was lowered as well, which compounds it." if guide == "lowered" else "")),
        "mixed": (
            "The signals point in different directions, so no single reading is clearly right. "
            "Read the guidance line before anything else."),
    }
    why = reasons.get(d, reasons["mixed"])
    if react is not None:
        why = ("The stock moved %+.1f%% the day after. " % react) + why

    # --- What the market cared about most ---
    if guide in ("raised", "lowered"):
        cared = ("Guidance. When guidance moves, it is almost always the thing being traded -- "
                 "the quarter is history, the guide is the thesis.")
    elif margin == "compressing":
        cared = ("Margins. Revenue can grow while the business gets worse, and this is what that "
                 "looks like.")
    elif rev_s is not None and rev_s < -2:
        cared = ("Revenue. A revenue miss is a demand problem, and demand problems are much harder "
                 "to fix than cost problems.")
    else:
        cared = "The headline numbers, with no single line item clearly dominating."

    # --- What changes the call ---
    watch = []
    if guide == "lowered":
        watch.append("Whether next quarter's guide stabilizes. One cut is a stumble; two is a trend.")
    if margin == "compressing":
        watch.append("Whether margins stop compressing. That is the number to check first next quarter.")
    if qa is not None and qa >= 0.6:
        watch.append("Whatever analysts kept circling on the call -- that is where the next surprise "
                     "usually comes from.")
    if not watch:
        watch.append("Whether the next quarter confirms this one. A single quarter is one data point.")

    return {
        "divergence_type": d,
        "what_happened": what,
        "what_management_said": " ".join(said),
        "why_the_stock_moved": why,
        "what_market_cared_about": cared,
        "what_changes_the_call": watch,
        "causation_caveat": ("These are the most likely readings given what is observable. Nobody "
                             "can know with certainty why a stock moved on a given day."),
    }


