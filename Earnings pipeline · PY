# =========================================================================== #
# 1. EARNINGS CALENDAR
# =========================================================================== #

def fetch_earnings_calendar(symbol, fmp_key=None):
    """Next scheduled report for one symbol. Returns dict or None.

    FMP first (it carries the session -- before/after market -- which matters enormously:
    a 4:05pm print gaps the stock overnight, an 8:00am print gaps it into the open).
    yfinance as the fallback so this still works if FMP is down.
    """
    if fmp_key:
        try:
            r = requests.get(FMP_BASE + "/api/v3/earning_calendar",
                             params={"apikey": fmp_key,
                                     "from": date.today().isoformat(),
                                     "to": (date.today() + timedelta(days=120)).isoformat()},
                             timeout=15)
            if r.status_code == 200:
                for row in (r.json() or []):
                    if str(row.get("symbol", "")).upper() == symbol.upper():
                        return {
                            "scheduled_at": row.get("date"),
                            "session": {"bmo": "bmo", "amc": "amc"}.get(
                                str(row.get("time", "")).lower(), "unknown"),
                            "eps_estimate": row.get("epsEstimated"),
                            "rev_estimate": row.get("revenueEstimated"),
                            "fiscal_period": row.get("fiscalDateEnding"),
                            "source": "fmp",
                        }
        except Exception as e:
            logger.warning("fmp earnings calendar %s: %s", symbol, e)

    try:
        import yfinance as yf
        info = yf.Ticker(symbol).info or {}
        ts = info.get("earningsTimestamp") or info.get("earningsTimestampStart")
        if ts:
            return {
                "scheduled_at": datetime.fromtimestamp(int(ts), tz=timezone.utc).isoformat(),
                "session": "unknown",
                "eps_estimate": info.get("epsForward"),
                "rev_estimate": None,
                "fiscal_period": None,
                "source": "yfinance",
            }
    except Exception as e:
        logger.warning("yf earnings calendar %s: %s", symbol, e)
    return None


# =========================================================================== #
# 2. RELEASE INGESTOR  —  SEC 8-K Item 2.02 / EX-99.1
#
# This is the free, fast path, and it is the one that matters. The 8-K hits
# EDGAR within minutes of the wire, and it is what gaps the stock at 4:05pm --
# an hour before anyone dials into the call.
# =========================================================================== #

_EPS_RE = re.compile(
    r"(?:diluted\s+)?(?:net\s+)?(?:earnings|income|loss)\s+per\s+(?:diluted\s+)?share[^$\d\-]{0,40}"
    r"\$?\s*(\(?-?[\d.]+\)?)", re.I)
_REV_RE = re.compile(
    r"(?:total\s+)?(?:net\s+)?revenue[s]?[^$\d]{0,40}\$\s*([\d,.]+)\s*(billion|million|thousand)?", re.I)
_GUIDE_UP = re.compile(
    r"rais(?:es|ing|ed)\s+(?:its\s+|full[- ]year\s+|fy\s*\d*\s*)?(?:guidance|outlook|forecast)|"
    r"increas(?:es|ing|ed)\s+(?:its\s+)?(?:guidance|outlook)|above (?:its )?prior (?:guidance|outlook)", re.I)
_GUIDE_DOWN = re.compile(
    r"low(?:ers|ering|ered)\s+(?:its\s+)?(?:guidance|outlook|forecast)|"
    r"reduc(?:es|ing|ed)\s+(?:its\s+)?(?:guidance|outlook)|"
    r"cut(?:s|ting)?\s+(?:its\s+)?(?:guidance|outlook)|"
    r"below (?:its )?prior (?:guidance|outlook)|withdraw(?:s|ing|n)? (?:its )?(?:guidance|outlook)", re.I)
_GUIDE_SAME = re.compile(
    r"reaffirm(?:s|ing|ed)|maintain(?:s|ing|ed)\s+(?:its\s+)?(?:guidance|outlook)|"
    r"reiterat(?:es|ing|ed)\s+(?:its\s+)?(?:guidance|outlook)", re.I)
_MARGIN_UP = re.compile(r"margin[s]?\s+(?:expand|improv|increas|grew|up)", re.I)
_MARGIN_DOWN = re.compile(r"margin[s]?\s+(?:compress|contract|declin|decreas|pressure|down)|"
                          r"pressure on margin", re.I)

_MULT = {"billion": 1e9, "million": 1e6, "thousand": 1e3, None: 1.0, "": 1.0}


def _num(s):
    try:
        s = str(s).strip()
        neg = s.startswith("(") and s.endswith(")")
        v = float(s.strip("()").replace(",", "").replace("$", ""))
        return -v if neg else v
    except Exception:
        return None


def parse_release(text):
    """Earnings press release -> the numbers and the direction of the story.

    Regex, not an LLM, for the NUMBERS -- a model that hallucinates an EPS figure is worse than no
    figure at all. The LLM is used for tone and themes, where being approximately right is fine.
    """
    body = re.sub(r"\s+", " ", re.sub(r"<[^>]+>", " ", text or ""))
    out = {"eps_actual": None, "rev_actual": None, "guidance_direction": "none",
           "guidance_text": None, "margin_direction": None}

    m = _EPS_RE.search(body)
    if m:
        out["eps_actual"] = _num(m.group(1))

    m = _REV_RE.search(body)
    if m:
        v = _num(m.group(1))
        if v is not None:
            out["rev_actual"] = v * _MULT.get((m.group(2) or "").lower(), 1.0)

    # Guidance direction. Order matters: an explicit cut beats a raise elsewhere in the doc.
    if _GUIDE_DOWN.search(body):
        out["guidance_direction"] = "lowered"
    elif _GUIDE_UP.search(body):
        out["guidance_direction"] = "raised"
    elif _GUIDE_SAME.search(body):
        out["guidance_direction"] = "reaffirmed"

    g = re.search(r"([^.]{0,200}(?:guidance|outlook)[^.]{0,240}\.)", body, re.I)
    if g:
        out["guidance_text"] = g.group(1).strip()[:600]

    if _MARGIN_DOWN.search(body):
        out["margin_direction"] = "compressing"
    elif _MARGIN_UP.search(body):
        out["margin_direction"] = "expanding"

    return out


def fetch_8k_release(symbol, cik, sec_get_fn, days_back=2):
    """Find today's 8-K Item 2.02 and pull Exhibit 99.1. Returns (text, url, filed_at) or None."""
    try:
        subs = sec_get_fn("https://data.sec.gov/submissions/CIK%s.json" % str(cik).zfill(10),
                          as_json=True)
        if not subs:
            return None
        recent = (subs.get("filings") or {}).get("recent") or {}
        forms = recent.get("form") or []
        accs = recent.get("accessionNumber") or []
        dates = recent.get("filingDate") or []
        items = recent.get("items") or []

        cutoff = date.today() - timedelta(days=days_back)
        for i, form in enumerate(forms):
            if form != "8-K":
                continue
            try:
                fdate = date.fromisoformat(dates[i])
            except Exception:
                continue
            if fdate < cutoff:
                break
            # Item 2.02 is the earnings release. Without it, an 8-K is some other event entirely.
            if EARNINGS_8K_ITEM not in str(items[i] if i < len(items) else ""):
                continue

            acc = accs[i].replace("-", "")
            base = "https://www.sec.gov/Archives/edgar/data/%s/%s" % (int(cik), acc)
            idx = sec_get_fn(base + "/index.json", as_json=True)
            if not idx:
                continue
            for item in ((idx.get("directory") or {}).get("item") or []):
                nm = str(item.get("name", "")).lower()
                if re.search(r"ex[-_]?99", nm) and nm.endswith((".htm", ".html", ".txt")):
                    url = base + "/" + item["name"]
                    txt = sec_get_fn(url) or ""
                    if len(txt) > 500:
                        return (txt[:300000], url, fdate.isoformat())
        return None
    except Exception as e:
        logger.warning("fetch_8k_release %s: %s", symbol, e)
        return None


