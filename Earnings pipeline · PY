# 7. PRE-EARNINGS BRIEF  (written BEFORE the print, never rewritten after)
# =========================================================================== #

def build_pre_brief(ev, hist_events=None):
    """Expectations, what matters, bull case, bear case, risk level.

    Written before the release and frozen. If this row ever gets updated with post-release
    knowledge, every backtest built on it becomes a lie.
    """
    eps_e = ev.get("eps_estimate")
    rev_e = ev.get("rev_estimate")
    hist = hist_events or []

    beats = [h for h in hist if (h.get("eps_surprise_pct") or 0) > 0]
    beat_rate = (len(beats) / len(hist) * 100) if hist else None
    avg_move = (sum(abs(h.get("reaction_1d_pct") or 0) for h in hist) / len(hist)) if hist else None

    pressure = []
    last = hist[0] if hist else None
    if last:
        if (last.get("guidance_direction") or "") == "lowered":
            pressure.append("They cut guidance last quarter. The market will want to know whether "
                            "that was a one-off or the start of something.")
        if (last.get("margin_direction") or "") == "compressing":
            pressure.append("Margins were compressing last quarter. Watch whether that stabilized.")
        if (last.get("qa_pressure") or 0) >= 0.6:
            pressure.append("Analysts pushed hard on the last call and did not get a satisfying "
                            "answer. Expect them to come back to it.")
    if not pressure:
        pressure.append("No unresolved issue carried over from last quarter. Guidance will likely "
                        "be the swing factor.")

    risk = "moderate"
    if avg_move is not None:
        if avg_move >= 8:
            risk = "high"
        elif avg_move <= 3:
            risk = "low"

    return {
        "eps_estimate": eps_e,
        "rev_estimate": rev_e,
        "beat_rate_pct": round(beat_rate, 0) if beat_rate is not None else None,
        "avg_abs_move_pct": round(avg_move, 1) if avg_move is not None else None,
        "risk_level": risk,
        "what_matters": pressure,
        "bull_case": ("If guidance is raised and margins hold, the quarter confirms the thesis. "
                      "Historically this name has beaten %s%% of the time."
                      % (int(beat_rate) if beat_rate is not None else "an unknown")),
        "bear_case": ("If guidance is cut, a good quarter will not save the stock -- the market "
                      "trades the outlook, not the past. Watch for margin commentary as the tell."),
        "expected_move_note": (
            "This name has moved an average of %.1f%% the day after its last %d reports. That is a "
            "rough guide to what is at stake, not a prediction."
            % (avg_move, len(hist)) if avg_move is not None else
            "Not enough history yet to say how much this name typically moves on earnings."),
    }


# =========================================================================== #
# 8. EVENT STATE MACHINE + POINT-IN-TIME FEATURE LOGGER
#
# THE ONE RULE: a feature row records what was known AT `as_of`. It is written
# once and never rewritten. Outcome labels are attached later by a job that may
# only read prices dated AFTER `as_of`.
#
# If you ever find yourself updating a PRE row with something learned from the
# release, stop. That single edit turns every backtest downstream into fiction --
# and it will look BETTER, which is exactly why it is so dangerous.
# =========================================================================== #

STATES = ("SCHEDULED", "PRE_BRIEF", "AWAITING_RELEASE", "RELEASE_PARSED",
          "CALL_IN_PROGRESS", "TRANSCRIPT_AVAILABLE", "POST_ANALYZED", "REACTION_LABELED")

_TRANSITIONS = {
    "SCHEDULED": {"PRE_BRIEF"},
    "PRE_BRIEF": {"AWAITING_RELEASE"},
    "AWAITING_RELEASE": {"RELEASE_PARSED"},
    "RELEASE_PARSED": {"CALL_IN_PROGRESS", "TRANSCRIPT_AVAILABLE", "POST_ANALYZED"},
    "CALL_IN_PROGRESS": {"TRANSCRIPT_AVAILABLE"},
    "TRANSCRIPT_AVAILABLE": {"POST_ANALYZED"},
    "POST_ANALYZED": {"REACTION_LABELED"},
    "REACTION_LABELED": set(),
}


def can_transition(frm, to):
    return to in _TRANSITIONS.get(frm, set())


def log_features(conn, event_id, symbol, stage, features, as_of=None):
    """Write ONE immutable row. ON CONFLICT DO NOTHING -- a stage is never rewritten.

    That DO NOTHING is not laziness. It is the enforcement mechanism: even a buggy caller cannot
    retroactively poison a pre-event row with post-event knowledge.
    """
    try:
        cur = conn.cursor()
        cur.execute(
            "INSERT INTO earnings_features (event_id, symbol, stage, as_of, features) "
            "VALUES (%s,%s,%s,%s,%s) ON CONFLICT (event_id, stage) DO NOTHING",
            (event_id, symbol.upper(), stage,
             as_of or datetime.now(timezone.utc), json.dumps(features, default=str)))
        conn.commit()
        cur.close()
        return True
    except Exception as e:
        logger.warning("log_features %s/%s: %s", symbol, stage, e)
        try:
            conn.rollback()
        except Exception:
            pass
        return False


def label_earnings_reactions(conn, closes_fn, bench_fn, max_events=100):
    """Attach the stock reaction to matured events.

    POINT-IN-TIME GUARANTEE: only bars dated strictly AFTER release_at are used. `price_before` is
    the last close on or before the release. Nothing else is permitted to touch these rows.
    """
    started = time.time()
    out = {"labeled": 0, "skipped": 0}
    cur = conn.cursor()
    cur.execute(
        "SELECT id, symbol, release_at, eps_surprise_pct, rev_surprise_pct, guidance_direction "
        "FROM earnings_events WHERE release_at IS NOT NULL AND reaction_labeled_at IS NULL "
        "AND release_at < NOW() - INTERVAL '2 days' ORDER BY release_at DESC LIMIT %s",
        (max_events,))
    rows = cur.fetchall() or []
    cur.close()

    bench = bench_fn() or []
    bmap = {d: c for d, c in bench}
    bdates = sorted(bmap.keys())

    for eid, sym, rel_at, eps_s, rev_s, guide in rows:
        try:
            closes = closes_fn(sym) or []
            if len(closes) < 5:
                out["skipped"] += 1
                continue
            cmap = {d: c for d, c in closes}
            cdates = sorted(cmap.keys())
            rel_date = rel_at.date() if hasattr(rel_at, "date") else rel_at

            prior = [d for d in cdates if d <= rel_date]
            future = [d for d in cdates if d > rel_date]     # STRICTLY after. This is the guarantee.
            if not prior or not future:
                out["skipped"] += 1
                continue

            base = cmap[prior[-1]]
            p1 = cmap[future[0]] if len(future) >= 1 else None
            p5 = cmap[future[4]] if len(future) >= 5 else None
            r1 = ((p1 - base) / base * 100.0) if (p1 and base) else None
            r5 = ((p5 - base) / base * 100.0) if (p5 and base) else None

            b1 = None
            bp = [d for d in bdates if d <= rel_date]
            bf = [d for d in bdates if d > rel_date]
            if bp and bf and bmap[bp[-1]]:
                b1 = (bmap[bf[0]] - bmap[bp[-1]]) / bmap[bp[-1]] * 100.0
            exc = (r1 - b1) if (r1 is not None and b1 is not None) else None

            ev = {"symbol": sym, "eps_surprise_pct": eps_s, "rev_surprise_pct": rev_s,
                  "guidance_direction": guide, "reaction_1d_pct": r1}
            expl = explain_event(ev)

            cur = conn.cursor()
            cur.execute(
                "UPDATE earnings_events SET price_before=%s, price_after_1d=%s, reaction_1d_pct=%s,"
                " reaction_5d_pct=%s, bench_1d_pct=%s, excess_1d_pct=%s,"
                " divergence_type=%s, explanation=%s, reaction_labeled_at=NOW(),"
                " state='REACTION_LABELED', updated_at=NOW() WHERE id=%s",
                (base, p1, r1, r5, b1, exc, expl["divergence_type"],
                 json.dumps(expl, default=str), eid))
            # Attach outcomes to every feature stage of this event -- labels only, never features.
            cur.execute(
                "UPDATE earnings_features SET fwd_ret_1d=%s, fwd_ret_5d=%s, fwd_excess_5d=%s,"
                " labeled_at=NOW() WHERE event_id=%s AND labeled_at IS NULL",
                (r1, r5, exc, eid))
            conn.commit()
            cur.close()
            out["labeled"] += 1
        except Exception as e:
            logger.warning("label_earnings_reactions %s: %s", sym, e)
            try:
                conn.rollback()
            except Exception:
                pass

    out["elapsed_sec"] = round(time.time() - started, 1)
    logger.info("earnings reactions labeled: %s", out)
    return out


def past_quarters(conn, symbol, n=8):
    """Last N quarters: outcome, tone, and how the stock reacted. Powers the history strip."""
    try:
        cur = conn.cursor()
        cur.execute(
            "SELECT fiscal_period, release_at, eps_surprise_pct, rev_surprise_pct,"
            " guidance_direction, mgmt_tone, reaction_1d_pct, divergence_type, event_score "
            "FROM earnings_events WHERE symbol=%s AND release_at IS NOT NULL "
            "ORDER BY release_at DESC LIMIT %s", (symbol.upper(), n))
        out = []
        for r in (cur.fetchall() or []):
            out.append({
                "period": r[0], "date": (str(r[1])[:10] if r[1] else None),
                "eps_surprise_pct": (round(float(r[2]), 1) if r[2] is not None else None),
                "rev_surprise_pct": (round(float(r[3]), 1) if r[3] is not None else None),
                "guidance": r[4], "tone": (round(float(r[5]), 2) if r[5] is not None else None),
                "reaction_1d_pct": (round(float(r[6]), 1) if r[6] is not None else None),
                "divergence": r[7], "event_score": r[8],
            })
        cur.close()
        return out
    except Exception as e:
        logger.warning("past_quarters %s: %s", symbol, e)
        return []


def earnings_for(conn, symbol):
    """Everything the stock page needs, in one shot. Returns None when there's nothing to show."""
    try:
        cur = conn.cursor()
        cur.execute(
            "SELECT id, fiscal_period, scheduled_at, session, state, eps_estimate, rev_estimate,"
            " eps_actual, rev_actual, eps_surprise_pct, rev_surprise_pct, release_at, release_url,"
            " guidance_direction, guidance_text, margin_direction, mgmt_tone, qa_pressure, themes,"
            " event_score, event_note, reaction_1d_pct, divergence_type, explanation,"
            " transcript_source, transcript_at "
            "FROM earnings_events WHERE symbol=%s "
            "ORDER BY COALESCE(release_at, scheduled_at) DESC LIMIT 1", (symbol.upper(),))
        r = cur.fetchone()
        cur.close()
        if not r:
            return None

        now = datetime.now(timezone.utc)
        sched = r[2]
        countdown = None
        if sched and not r[11]:
            try:
                countdown = int((sched - now).total_seconds())
            except Exception:
                countdown = None

        return {
            "event_id": r[0], "period": r[1],
            "scheduled_at": (str(sched) if sched else None),
            "session": r[3], "state": r[4],
            "countdown_seconds": countdown,
            "is_upcoming": bool(countdown and countdown > 0),
            "eps_estimate": (float(r[5]) if r[5] is not None else None),
            "rev_estimate": (float(r[6]) if r[6] is not None else None),
            "eps_actual": (float(r[7]) if r[7] is not None else None),
            "rev_actual": (float(r[8]) if r[8] is not None else None),
            "eps_surprise_pct": (round(float(r[9]), 1) if r[9] is not None else None),
            "rev_surprise_pct": (round(float(r[10]), 1) if r[10] is not None else None),
            "release_at": (str(r[11]) if r[11] else None),
            "release_url": r[12],
            "guidance_direction": r[13], "guidance_text": r[14],
            "margin_direction": r[15],
            "mgmt_tone": (float(r[16]) if r[16] is not None else None),
            "qa_pressure": (float(r[17]) if r[17] is not None else None),
            "themes": r[18] or [],
            "event_score": r[19], "event_note": r[20],
            "reaction_1d_pct": (round(float(r[21]), 1) if r[21] is not None else None),
            "divergence_type": r[22],
            "explanation": r[23],
            "transcript_source": r[24],
            "has_transcript": bool(r[25]),
            # HONEST: we do not have a live feed. Never claim we do.
            "live_transcript_available": False,
            "history": past_quarters(conn, symbol, 8),
        }
    except Exception as e:
        logger.warning("earnings_for %s: %s", symbol, e)
        return None
