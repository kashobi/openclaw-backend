# 4. SIGNAL SCORING
# ===========================================================================

def score_contract(row, market_cap=None):
    """0-100, plus the plain-English reason. The core insight the whole product
    rests on: SIZE RELATIVE TO THE COMPANY is the signal, not size in dollars.

    A $200M award is a rounding error to Lockheed ($100B+ cap) and a
    company-altering event for AeroVironment. Same headline, opposite trade.
    """
    amt = float(row.get("headline_amount") or 0)
    pts, why = 0, []

    ratio = None
    if market_cap and market_cap > 0:
        ratio = amt / float(market_cap)
        if ratio >= 0.50:
            pts += 45; why.append("award equals %.0f%% of the company's entire market cap" % (ratio * 100))
        elif ratio >= 0.20:
            pts += 38; why.append("award is %.0f%% of market cap -- materially changes the company" % (ratio * 100))
        elif ratio >= 0.10:
            pts += 30; why.append("award is %.0f%% of market cap" % (ratio * 100))
        elif ratio >= 0.03:
            pts += 18; why.append("award is %.1f%% of market cap -- meaningful but not transformative" % (ratio * 100))
        else:
            pts += 5;  why.append("award is under 3% of market cap -- unlikely to move the stock on its own")

    # Cash beats a ceiling. An IDIQ ceiling is permission to spend, not spending.
    if row.get("is_idiq"):
        pts += 8
        why.append("IDIQ ceiling, not funded cash -- this is a spending CAP the DoD may never use")
    else:
        pts += 22
        why.append("definite award -- funded, not a ceiling")

    # Sole-source means no price competition, which historically means fatter margins.
    if row.get("is_sole_source"):
        pts += 18
        why.append("sole-source: no competitor bid it down, so margins are typically higher")
    elif row.get("competition") == "COMPETED":
        pts += 8
        why.append("competitively awarded")

    if row.get("is_modification"):
        pts -= 10
        why.append("a modification to existing work, not new business")

    if amt >= 1e9:
        pts += 12; why.append("over $1 billion")
    elif amt >= 5e8:
        pts += 7

    pts = max(0, min(100, pts))
    return {
        "signal_score": pts,
        "pure_play_ratio": ratio,
        "is_pure_play": bool(ratio and ratio >= 0.10),
        "signal_note": "; ".join(why),
    }


# ===========================================================================
# 5. INGESTION — defense.gov (the SIGNAL: same-day, 5pm ET)
# ===========================================================================

def _hash(*parts):
    return hashlib.sha256("|".join(str(p or "") for p in parts).encode()).hexdigest()[:32]


_IDIQ_RE = re.compile(r"indefinite[- ]delivery|IDIQ|ordering period|ceiling", re.I)
_SOLE_RE = re.compile(r"sole[- ]source|not competitively procured|one (?:offer|bid) (?:was )?received|"
                      r"pursuant to 10 U\.S\. Code 3204", re.I)
_COMP_RE = re.compile(r"competitively procured|(\d+)\s+offers? (?:were )?received", re.I)
_MOD_RE  = re.compile(r"\bmodification\b|\boption\b (?:is )?exercis", re.I)
_BRANCH_RE = re.compile(r"\b(Army|Navy|Air Force|Space Force|Marine Corps|"
                        r"Defense Logistics Agency|Missile Defense Agency|"
                        r"Special Operations Command|Defense Advanced Research)\b", re.I)


def parse_defense_gov_entry(text, announced):
    """One announcement paragraph -> a contract row, or None if below the floor.

    THE FLOOR IS APPLIED HERE, on a normalized dollar value. Nothing under
    $100M is returned, so nothing under $100M can ever reach the database.
    """
    amt = max_usd(text)
    if amt < DOD_VALUE_FLOOR:
        return None

    # The recipient is the leading clause, before the comma and the city.
    m = re.match(r"\s*([^,]{3,90})\s*,", text or "")
    recipient = (m.group(1) if m else "").strip()
    if not recipient:
        return None

    is_idiq = bool(_IDIQ_RE.search(text))
    is_mod = bool(_MOD_RE.search(text))
    sole = bool(_SOLE_RE.search(text))
    comp = _COMP_RE.search(text)
    br = _BRANCH_RE.search(text)

    return {
        "contract_hash": _hash(recipient, round(amt), announced),
        "announced_date": announced,
        "recipient_name": recipient,
        "obligated_amount": None if is_idiq else amt,
        "ceiling_amount": amt if is_idiq else None,
        "headline_amount": amt,                       # max(obligated, ceiling) by construction
        "award_type": "MODIFICATION" if is_mod else ("IDIQ" if is_idiq else "DEFINITE"),
        "is_idiq": is_idiq,
        "is_modification": is_mod,
        "is_sole_source": sole,
        "competition": "SOLE_SOURCE" if sole else ("COMPETED" if comp else None),
        "branch": br.group(1) if br else None,
        "description": (text or "")[:2000],
        "source": "defense.gov",
        "source_url": DEFENSE_CONTRACTS_URL,
        "raw": {"text": (text or "")[:4000]},
    }


def fetch_defense_gov(day=None):
    """Scrape the 5pm ET daily announcements. Returns only $100M+ rows."""
    day = day or date.today()
    out = []
    try:
        r = requests.get(DEFENSE_CONTRACTS_URL, headers=UA, timeout=20)
        if r.status_code != 200:
            logger.warning("defense.gov -> %s", r.status_code)
            return out
        # Announcements are paragraph blocks. Strip tags, split on blank lines.
        html = re.sub(r"<script.*?</script>|<style.*?</style>", " ", r.text, flags=re.S | re.I)
        txt = re.sub(r"<[^>]+>", "\n", html)
        blocks = [b.strip() for b in re.split(r"\n\s*\n", txt) if "$" in b and len(b.strip()) > 80]
        for b in blocks:
            row = parse_defense_gov_entry(b, day)
            if row:
                out.append(row)
    except Exception as e:
        logger.error("fetch_defense_gov: %s", e)
    logger.info("defense.gov: %d contracts over the $100M floor", len(out))
    return out


