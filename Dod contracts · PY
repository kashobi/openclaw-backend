# ===========================================================================
# 2. VALUE PARSING  —  the bug that would have killed the product
# ===========================================================================

_AMT_RE = re.compile(
    r"\$\s*([\d,]+(?:\.\d+)?)\s*(trillion|billion|million|thousand)?",
    re.IGNORECASE,
)
_MULT = {
    None: 1.0, "": 1.0,
    "thousand": 1e3, "million": 1e6, "billion": 1e9, "trillion": 1e12,
}


def parse_usd(text):
    """Every dollar figure in `text`, normalized to a float USD value.

    THIS is the function the original spec got wrong. The spec said: match
    'million' or 'billion' and keep the row if the PREFIX NUMBER is >= 100.
    Under that rule "$1.2 billion" has a prefix of 1.2, fails 1.2 >= 100, and
    is discarded -- so every contract between $100M and $100B, which is all of
    them, gets silently dropped. The magnitude word must be applied BEFORE the
    comparison, not after.

        parse_usd("$1.2 billion")     -> [1200000000.0]
        parse_usd("$99,500,000")      -> [99500000.0]
        parse_usd("$250 million")     -> [250000000.0]
    """
    out = []
    for num, mult in _AMT_RE.findall(text or ""):
        try:
            v = float(num.replace(",", "")) * _MULT[(mult or "").lower()]
            out.append(v)
        except Exception:
            continue
    return out


def max_usd(text):
    vals = parse_usd(text)
    return max(vals) if vals else 0.0


