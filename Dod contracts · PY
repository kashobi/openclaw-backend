def fetch_usaspending(days_back=30, page_limit=10):
    """POST /api/v2/search/spending_by_award/ with the $100M floor in the payload.

    NOTE ON THE FLOOR: award_amounts.lower_bound filters on the award amount as
    USAspending reports it. For IDVs that is often the obligated figure, NOT the
    ceiling -- which is why a $9B ceiling with $2M obligated can slip through the
    server-side filter. So we ALSO pull IDV award types and re-test the floor
    locally against max(obligated, ceiling). Server-side filtering alone would
    quietly lose the biggest announcements in the system.
    """
    end = date.today()
    start = end - timedelta(days=days_back)
    out = []

    payload = {
        "subawards": False,
        "limit": 100,
        "page": 1,
        "sort": "Award Amount",
        "order": "desc",
        "filters": {
            "time_period": [{"start_date": start.isoformat(), "end_date": end.isoformat()}],
            "agencies": [{"type": "awarding", "tier": "toptier",
                          "name": "Department of Defense"}],
            # A/B/C/D = contract award types; IDV_* = the ceiling vehicles we must not miss.
            "award_type_codes": ["A", "B", "C", "D",
                                 "IDV_A", "IDV_B", "IDV_B_A", "IDV_B_B", "IDV_B_C",
                                 "IDV_C", "IDV_D", "IDV_E"],
            "award_amounts": [{"lower_bound": DOD_VALUE_FLOOR}],
        },
        "fields": [
            "Award ID", "Recipient Name", "Recipient UEI",
            "Award Amount", "Total Outlays",
            "Start Date", "End Date",
            "Awarding Agency", "Awarding Sub Agency",
            "Contract Award Type", "Award Type",
            "NAICS", "PSC", "Description",
            "generated_internal_id",
        ],
    }

    for page in range(1, page_limit + 1):
        payload["page"] = page
        try:
            r = requests.post(USASPENDING + "/search/spending_by_award/",
                              json=payload, headers=UA, timeout=30)
            if r.status_code != 200:
                logger.warning("usaspending -> %s %s", r.status_code, r.text[:200])
                break
            data = r.json()
            results = data.get("results") or []
            if not results:
                break
            for a in results:
                amt = float(a.get("Award Amount") or 0)
                ceiling = float(a.get("Total Outlays") or 0)
                headline = max(amt, ceiling)
                if headline < DOD_VALUE_FLOOR:      # re-test locally; see the note above
                    continue
                atype = str(a.get("Award Type") or a.get("Contract Award Type") or "")
                is_idv = atype.upper().startswith("IDV") or "INDEFINITE" in atype.upper()
                out.append({
                    "contract_hash": _hash(a.get("Award ID"), a.get("Recipient Name"), round(headline)),
                    "announced_date": a.get("Start Date") or date.today().isoformat(),
                    "action_date": a.get("Start Date"),
                    "recipient_name": a.get("Recipient Name") or "",
                    "recipient_uei": a.get("Recipient UEI"),
                    "obligated_amount": amt or None,
                    "ceiling_amount": ceiling or None,
                    "headline_amount": headline,
                    "award_type": "IDIQ" if is_idv else "DEFINITE",
                    "is_idiq": is_idv,
                    "is_modification": False,
                    "naics_code": (a.get("NAICS") or {}).get("code") if isinstance(a.get("NAICS"), dict) else a.get("NAICS"),
                    "psc_code": (a.get("PSC") or {}).get("code") if isinstance(a.get("PSC"), dict) else a.get("PSC"),
                    "branch": a.get("Awarding Sub Agency"),
                    "completion_date": a.get("End Date"),
                    "description": (a.get("Description") or "")[:2000],
                    "piid": a.get("Award ID"),
                    "source": "usaspending",
                    "source_url": "https://www.usaspending.gov/award/" + str(a.get("generated_internal_id") or ""),
                    "raw": a,
                })
            if not data.get("page_metadata", {}).get("hasNext"):
                break
            time.sleep(0.4)
        except Exception as e:
            logger.error("fetch_usaspending page %s: %s", page, e)
            break

    logger.info("usaspending: %d contracts over the $100M floor", len(out))
    return out


