def upsert_contract(conn, row, market_cap_lookup=None):
    """Resolve the entity, score it, write it. The floor is asserted one final
    time here so no code path can ever slip a sub-$100M row into production."""
    if float(row.get("headline_amount") or 0) < DOD_VALUE_FLOOR:
        return False

    ent = resolve_entity(conn, row.get("recipient_name"),
                         row.get("recipient_uei"), row.get("recipient_cage"))
    jv = parse_joint_venture(conn, row.get("recipient_name"), row.get("description"))

    mcap = None
    if ent["ticker"] and market_cap_lookup:
        try:
            mcap = market_cap_lookup(ent["ticker"])
        except Exception:
            mcap = None

    sig = score_contract(row, mcap)

    cur = conn.cursor()
    cur.execute(
        "INSERT INTO dod_contracts "
        "(contract_hash, announced_date, action_date, recipient_name, recipient_uei, recipient_cage,"
        " ticker, parent_name, resolution_method, resolution_conf,"
        " obligated_amount, ceiling_amount, headline_amount,"
        " award_type, is_idiq, is_modification, competition, is_sole_source,"
        " branch, naics_code, psc_code, completion_date, description, piid,"
        " source, source_url, raw, pure_play_ratio, is_pure_play, signal_score, signal_note,"
        " is_jv, jv_partners, needs_review) "
        "VALUES (%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s) "
        "ON CONFLICT (contract_hash) DO UPDATE SET "
        "  recipient_uei = COALESCE(EXCLUDED.recipient_uei, dod_contracts.recipient_uei),"
        "  obligated_amount = COALESCE(EXCLUDED.obligated_amount, dod_contracts.obligated_amount),"
        "  ceiling_amount = COALESCE(EXCLUDED.ceiling_amount, dod_contracts.ceiling_amount),"
        "  naics_code = COALESCE(EXCLUDED.naics_code, dod_contracts.naics_code),"
        "  psc_code = COALESCE(EXCLUDED.psc_code, dod_contracts.psc_code),"
        "  ticker = COALESCE(dod_contracts.ticker, EXCLUDED.ticker),"
        "  enriched_at = NOW() "
        "RETURNING id",
        (row["contract_hash"], row["announced_date"], row.get("action_date"),
         row.get("recipient_name"), row.get("recipient_uei"), row.get("recipient_cage"),
         ent["ticker"], ent["parent_name"], ent["method"], ent["confidence"],
         row.get("obligated_amount"), row.get("ceiling_amount"), row["headline_amount"],
         row.get("award_type"), row.get("is_idiq", False), row.get("is_modification", False),
         row.get("competition"), row.get("is_sole_source"),
         row.get("branch"), row.get("naics_code"), row.get("psc_code"),
         row.get("completion_date"), row.get("description"), row.get("piid"),
         row["source"], row.get("source_url"), json.dumps(row.get("raw") or {}),
         sig["pure_play_ratio"], sig["is_pure_play"], sig["signal_score"], sig["signal_note"],
         bool(jv), json.dumps(jv) if jv else None,
         ent["needs_review"]),
    )
    cid = (cur.fetchone() or [None])[0]

    # Open an impact row the day the contract is announced -- labels get attached later,
    # by a job that may only read prices dated AFTER announced_date. Same point-in-time
    # discipline as the feature store.
    if cid and ent["ticker"] and not ent["needs_review"]:
        cur.execute(
            "INSERT INTO historical_stock_impact (contract_id, ticker, announced_date, market_cap_at_announce) "
            "VALUES (%s,%s,%s,%s) ON CONFLICT (contract_id, ticker) DO NOTHING",
            (cid, ent["ticker"], row["announced_date"], mcap))
    conn.commit()
    cur.close()
    return True


def run_dod_pipeline(conn, market_cap_lookup=None):
    """Daily entry point. defense.gov first (the signal), then enrichment."""
    started = time.time()
    cur = conn.cursor()
    cur.execute(SCHEMA)
    conn.commit()
    cur.close()
    seed_organizations(conn)

    summary = {"defense_gov": 0, "usaspending": 0, "sam_gov": 0,
               "stored": 0, "needs_review": 0}

    for src, rows in (("defense_gov", fetch_defense_gov()),
                      ("usaspending", fetch_usaspending()),
                      ("sam_gov", fetch_sam_opportunities())):
        summary[src] = len(rows)
        for row in rows:
            try:
                if upsert_contract(conn, row, market_cap_lookup):
                    summary["stored"] += 1
            except Exception as e:
                logger.error("upsert %s: %s", row.get("contract_hash"), e)
                conn.rollback()

    cur = conn.cursor()
    cur.execute("SELECT COUNT(*) FROM dod_contracts WHERE needs_review")
    summary["needs_review"] = (cur.fetchone() or [0])[0]
    cur.close()

    summary["elapsed_sec"] = round(time.time() - started, 1)
    logger.info("dod pipeline: %s", summary)
    return summary


# ===========================================================================
# 9. EXHIBIT 21 HARVESTER  —  the crosswalk nobody sells you
#
# Every 10-K carries Exhibit 21, "Subsidiaries of the Registrant": a list of
# every entity the company owns. It is filed under oath, it is free, and it is
# EXACTLY the parent->subsidiary map we need to roll a contract awarded to
# "Sikorsky Aircraft" up to LMT.
#
# No vendor sells a UEI->ticker crosswalk. This builds one from primary
# sources, which means it costs nothing, cannot be taken away, and gets better
# every year as new 10-Ks are filed.
#
# Rate limits: the SEC allows 10 requests/second and REQUIRES a real
# User-Agent with contact info. Violate either and you get blocked by IP.
# ===========================================================================

SEC_UA = {"User-Agent": os.environ.get("SEC_USER_AGENT", "ApexQ contact@apexq.io")}
SEC_TICKERS_URL = "https://www.sec.gov/files/company_tickers.json"

# Subsidiary lists are noisy. These lines are structure, not companies.
_EX21_NOISE = re.compile(
    r"^\s*$|subsidiaries of|state or |jurisdiction|incorporation|organization|"
    r"^name\b|^entity\b|^\d+$|^page |^exhibit|percent|ownership|registrant|"
    r"^\(?[a-z]\)?$|^table of|united states|delaware|^see |^\*",
    re.IGNORECASE,
)
_JURIS = re.compile(
    r"\b(delaware|nevada|california|texas|virginia|maryland|new york|florida|"
    r"connecticut|massachusetts|ohio|arizona|colorado|washington|england|wales|"
    r"united kingdom|canada|germany|france|israel|japan|australia|netherlands|"
    r"switzerland|luxembourg|singapore|india|ireland|scotland|italy|spain|sweden)\b",
    re.IGNORECASE,
)


def _sec_get(url, as_json=False):
    """SEC fetch with the required identifying header and their rate limit respected."""
    try:
        r = requests.get(url, headers=SEC_UA, timeout=20)
        time.sleep(0.12)          # ~8 req/s, comfortably under the SEC's 10/s ceiling
        if r.status_code != 200:
            logger.warning("SEC %s -> %s", url, r.status_code)
            return None
        return r.json() if as_json else r.text
    except Exception as e:
        logger.warning("SEC fetch %s: %s", url, e)
        return None


def sec_ticker_to_cik():
    """{TICKER: zero-padded CIK}. Cached in-process; the file changes rarely."""
    if getattr(sec_ticker_to_cik, "_cache", None):
        return sec_ticker_to_cik._cache
    out = {}
    data = _sec_get(SEC_TICKERS_URL, as_json=True) or {}
    for row in data.values():
        t = str(row.get("ticker", "")).upper()
        if t:
            out[t] = str(row.get("cik_str", "")).zfill(10)
    sec_ticker_to_cik._cache = out
    logger.info("SEC ticker map: %d tickers", len(out))
    return out


def _latest_10k_accession(cik):
    """Accession number of the most recent 10-K, or None."""
    d = _sec_get("https://data.sec.gov/submissions/CIK%s.json" % cik, as_json=True)
    if not d:
        return None
    recent = (d.get("filings") or {}).get("recent") or {}
    forms = recent.get("form") or []
    accs = recent.get("accessionNumber") or []
    for form, acc in zip(forms, accs):
        if form in ("10-K", "10-K405", "10-KSB"):
            return acc.replace("-", "")
    return None


def _find_ex21_doc(cik, accession):
    """URL of the Exhibit 21 document inside a filing, or None."""
    base = "https://www.sec.gov/Archives/edgar/data/%s/%s" % (int(cik), accession)
    idx = _sec_get(base + "/index.json", as_json=True)
    if not idx:
        return None
    for item in ((idx.get("directory") or {}).get("item") or []):
        nm = str(item.get("name", "")).lower()
        # EX-21 shows up as ex21.htm, ex-21.1.htm, exhibit21.htm, a2234567zex-21.htm ...
        if re.search(r"ex[-_]?21", nm) and nm.endswith((".htm", ".html", ".txt")):
            return base + "/" + item.get("name")
    return None


def parse_exhibit21(html):
    """Exhibit 21 text -> a list of subsidiary names.

    Deliberately conservative. A false subsidiary ("Delaware") mapped to a
    ticker is far more damaging than a missed one: it would attribute a real
    $100M contract to the wrong public company. When in doubt, drop the line.
    """
    if not html:
        return []
    txt = re.sub(r"<script.*?</script>|<style.*?</style>", " ", html, flags=re.S | re.I)
    txt = re.sub(r"</(td|tr|p|div|li|h\d)>", "\n", txt, flags=re.I)
    txt = re.sub(r"<[^>]+>", " ", txt)
    txt = txt.replace("&amp;", "&").replace("&nbsp;", " ").replace("&#39;", "'")

    names, seen = [], set()
    for raw in txt.split("\n"):
        line = re.sub(r"\s+", " ", raw).strip(" .\t|-")
        if not line or len(line) < 4 or len(line) > 120:
            continue
        if _EX21_NOISE.match(line):
            continue
        # Strip a trailing jurisdiction column: "Sikorsky Aircraft Corporation  Delaware"
        line = _JURIS.sub("", line).strip(" ,.-|")
        if len(line) < 4:
            continue
        # A real company name has a corporate marker or at least two capitalized words.
        has_suffix = re.search(r"\b(inc|corp|corporation|company|co|llc|ltd|limited|lp|plc|"
                               r"gmbh|s\.a|b\.v|holdings|group|systems|technologies)\b\.?",
                               line, re.IGNORECASE)
        caps = len(re.findall(r"\b[A-Z][a-zA-Z&'.-]+", line))
        if not has_suffix and caps < 2:
            continue
        if re.match(r"^\d", line):
            continue
        key = normalize_name(line)
        if not key or len(key) < 3 or key in seen:
            continue
        seen.add(key)
        names.append(line)
    return names


def harvest_exhibit21(conn, tickers=None, limit=40):
    """Pull Exhibit 21 for each public parent and write the subsidiaries into the crosswalk.

    Rows land as source='exhibit21', confidence=0.95 -- high, because the company itself
    swore to the list, but not 1.0, because our HTML parsing is a heuristic.
    """
    started = time.time()
    summary = {"parents": 0, "subsidiaries": 0, "skipped": 0, "errors": 0}

    if not tickers:
        cur = conn.cursor()
        cur.execute("SELECT DISTINCT parent_ticker FROM organizations_mapping "
                    "WHERE parent_ticker IS NOT NULL ORDER BY parent_ticker LIMIT %s", (limit,))
        tickers = [r[0] for r in (cur.fetchall() or [])]
        cur.close()

    cikmap = sec_ticker_to_cik()

    for t in tickers:
        cik = cikmap.get(str(t).upper())
        if not cik:
            summary["skipped"] += 1
            continue
        try:
            acc = _latest_10k_accession(cik)
            if not acc:
                summary["skipped"] += 1
                continue
            url = _find_ex21_doc(cik, acc)
            if not url:
                summary["skipped"] += 1
                continue
            subs = parse_exhibit21(_sec_get(url))
            if not subs:
                summary["skipped"] += 1
                continue

            summary["parents"] += 1
            cur = conn.cursor()
            cur.execute("SELECT parent_name FROM organizations_mapping "
                        "WHERE parent_ticker=%s AND ticker=%s LIMIT 1", (t, t))
            r = cur.fetchone()
            pname = r[0] if r else t

            for name in subs:
                # DO NOT overwrite a seed or a human-verified row. Those are ground truth;
                # this is a heuristic. ON CONFLICT DO NOTHING is the whole safety story.
                cur.execute(
                    "INSERT INTO organizations_mapping "
                    "(legal_name, normalized_name, ticker, parent_ticker, parent_name,"
                    " is_public, is_subsidiary, source, confidence, verified, notes) "
                    "VALUES (%s,%s,NULL,%s,%s,FALSE,TRUE,'exhibit21',0.95,FALSE,%s) "
                    "ON CONFLICT (normalized_name) DO NOTHING",
                    (name, normalize_name(name), t, pname,
                     "from %s 10-K Exhibit 21" % t))
                summary["subsidiaries"] += 1
            conn.commit()
            cur.close()
            logger.info("exhibit21 %s: %d subsidiaries", t, len(subs))
        except Exception as e:
            summary["errors"] += 1
            logger.error("harvest_exhibit21 %s: %s", t, e)
            try:
                conn.rollback()
            except Exception:
                pass

    summary["elapsed_sec"] = round(time.time() - started, 1)
    logger.info("exhibit21 harvest: %s", summary)
    return summary


def backfill_unresolved(conn, limit=200):
    """Re-run entity resolution on rows that had no ticker.

    Run this after every harvest: a contract that was unresolvable in January
    can become resolvable in February once the parent's new 10-K lands. The
    review queue should shrink on its own over time.
    """
    cur = conn.cursor()
    cur.execute(
        "SELECT id, recipient_name, recipient_uei, recipient_cage FROM dod_contracts "
        "WHERE ticker IS NULL ORDER BY headline_amount DESC LIMIT %s", (limit,))
    rows = cur.fetchall() or []
    cur.close()

    fixed = 0
    for cid, name, uei, cage in rows:
        ent = resolve_entity(conn, name, uei, cage)
        if ent["ticker"] and not ent["needs_review"]:
            cur = conn.cursor()
            cur.execute(
                "UPDATE dod_contracts SET ticker=%s, parent_name=%s, resolution_method=%s,"
                " resolution_conf=%s, needs_review=FALSE WHERE id=%s",
                (ent["ticker"], ent["parent_name"], ent["method"], ent["confidence"], cid))
            cur.execute(
                "INSERT INTO historical_stock_impact (contract_id, ticker, announced_date) "
                "SELECT id, %s, announced_date FROM dod_contracts WHERE id=%s "
                "ON CONFLICT (contract_id, ticker) DO NOTHING", (ent["ticker"], cid))
            conn.commit()
            cur.close()
            fixed += 1
    logger.info("backfill_unresolved: resolved %d of %d", fixed, len(rows))
    return {"checked": len(rows), "resolved": fixed}
