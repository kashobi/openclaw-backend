_SUFFIXES = re.compile(
    r"\b(inc|incorporated|corp|corporation|co|company|llc|l\.l\.c|ltd|limited|lp|l\.p|plc|"
    r"holdings|holding|group|technologies|technology|systems|solutions|industries|"
    r"international|intl|usa|us|america|american|the|and)\b\.?",
    re.IGNORECASE,
)


def normalize_name(name):
    """Company name -> a join key. Aggressive on purpose: the government writes
    'LOCKHEED MARTIN CORP.', 'Lockheed Martin Corporation', and
    'Lockheed Martin Aeronautics Co.' for what is, to a stock, one company."""
    n = (name or "").lower()
    n = n.replace("&", " and ")      # DoD writes "Pratt & Whitney"; our seed says "Pratt and Whitney"
    n = re.sub(r"[^a-z0-9\s]", " ", n)
    n = _SUFFIXES.sub(" ", n)
    n = re.sub(r"\s+", " ", n).strip()
    return n


