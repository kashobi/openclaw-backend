def fetch_sam_opportunities(days_ahead=90):
    """Pre-solicitations and RFPs above the floor. This is the only source that
    is ahead of the market rather than behind it -- an RFP tells you money is
    coming before anyone has won it."""
    if not SAM_API_KEY:
        logger.info("SAM_API_KEY not set; skipping pre-solicitations")
        return []
    out = []
    try:
        params = {
            "api_key": SAM_API_KEY,
            "postedFrom": (date.today() - timedelta(days=30)).strftime("%m/%d/%Y"),
            "postedTo": date.today().strftime("%m/%d/%Y"),
            "ptype": "p,o,r",          # presolicitation, solicitation, sources sought
            "deptname": "DEPT OF DEFENSE",
            "limit": 200,
        }
        r = requests.get(SAM_API, params=params, headers=UA, timeout=30)
        if r.status_code != 200:
            logger.warning("sam.gov -> %s", r.status_code)
            return out
        for o in (r.json().get("opportunitiesData") or []):
            blob = (o.get("title") or "") + " " + (o.get("description") or "")
            amt = max_usd(blob)
            if amt < DOD_VALUE_FLOOR:
                continue
            out.append({
                "contract_hash": _hash(o.get("noticeId")),
                "announced_date": (o.get("postedDate") or "")[:10] or date.today().isoformat(),
                "recipient_name": "(not yet awarded)",
                "headline_amount": amt,
                "ceiling_amount": amt,
                "award_type": "OTHER",
                "is_idiq": False,
                "is_modification": False,
                "branch": o.get("fullParentPathName"),
                "description": blob[:2000],
                "source": "sam.gov",
                "source_url": o.get("uiLink"),
                "raw": o,
            })
    except Exception as e:
        logger.error("fetch_sam_opportunities: %s", e)
    return out


