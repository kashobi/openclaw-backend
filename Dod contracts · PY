def seed_organizations(conn):
    """Idempotent. Safe on every boot."""
    cur = conn.cursor()
    for legal, ticker, parent, pname in SEED_ORGS:
        cur.execute(
            "INSERT INTO organizations_mapping "
            "(legal_name, normalized_name, ticker, parent_ticker, parent_name, is_public, "
            " is_subsidiary, source, confidence, verified) "
            "VALUES (%s,%s,%s,%s,%s,%s,%s,'seed',1.0,TRUE) "
            "ON CONFLICT (normalized_name) DO NOTHING",
            (legal, normalize_name(legal), ticker, parent, pname,
             bool(parent), ticker is None and parent is not None),
        )
    conn.commit()
    cur.close()


def resolve_entity(conn, recipient_name, uei=None, cage=None):
    """UEI/CAGE/name -> ticker, with an honest confidence.

    Order matters: exact identifiers first, then the normalized name, then a
    containment match, and only then fuzzy. Anything below 0.85 is flagged for
    human review rather than published.

    Returns dict(ticker, parent_name, method, confidence, needs_review).
    """
    cur = conn.cursor()
    miss = {"ticker": None, "parent_name": None, "method": None,
            "confidence": 0.0, "needs_review": True}

    # 1. UEI / CAGE -- unambiguous when present.
    for col, val in (("uei", uei), ("cage", cage)):
        if not val:
            continue
        cur.execute(
            "SELECT parent_ticker, parent_name, source, confidence FROM organizations_mapping "
            "WHERE %s = %%s AND parent_ticker IS NOT NULL LIMIT 1" % col, (val,))
        r = cur.fetchone()
        if r:
            cur.close()
            return {"ticker": r[0], "parent_name": r[1], "method": col,
                    "confidence": 1.0, "needs_review": False}

    norm = normalize_name(recipient_name)
    if not norm:
        cur.close()
        return miss

    # 2. Exact normalized name.
    cur.execute(
        "SELECT parent_ticker, parent_name, source, confidence FROM organizations_mapping "
        "WHERE normalized_name = %s LIMIT 1", (norm,))
    r = cur.fetchone()
    if r:
        cur.close()
        # A row that resolves to no public parent is a RESOLVED PRIVATE COMPANY, not a
        # failure. Saying "Anduril, private" is correct and useful; guessing a ticker is not.
        return {"ticker": r[0], "parent_name": r[1], "method": r[2],
                "confidence": float(r[3] or 1.0), "needs_review": False}

    # 3. Containment. "lockheed martin aeronautics" contains the seed "lockheed martin".
    cur.execute(
        "SELECT parent_ticker, parent_name, normalized_name FROM organizations_mapping "
        "WHERE parent_ticker IS NOT NULL AND %s LIKE '%%' || normalized_name || '%%' "
        "ORDER BY LENGTH(normalized_name) DESC LIMIT 1", (norm,))
    r = cur.fetchone()
    if r:
        conf = 0.90 if len(r[2]) >= 8 else 0.70   # short keys match by accident
        cur.close()
        return {"ticker": r[0], "parent_name": r[1], "method": "fuzzy",
                "confidence": conf, "needs_review": conf < 0.85}

    # 4. Unknown. Queue it. Never guess a ticker onto a $100M headline.
    cur.execute(
        "INSERT INTO organizations_mapping (legal_name, normalized_name, source, confidence, verified) "
        "VALUES (%s,%s,'fuzzy',0.0,FALSE) ON CONFLICT (normalized_name) DO NOTHING",
        (recipient_name, norm))
    conn.commit()
    cur.close()
    return miss


# --- Joint ventures --------------------------------------------------------
_JV_SPLIT = re.compile(r"\band\b|,|/|&|\bjoint venture\b|\bJV\b", re.IGNORECASE)


def parse_joint_venture(conn, recipient_name, description=""):
    """A JV award names two or more parents. Credit both, never double-count.

    Absent an explicit split in the text, shares are left NULL rather than
    assumed 50/50 -- an invented split is worse than an honest unknown.
    """
    blob = (recipient_name or "") + " " + (description or "")
    if not re.search(r"joint venture|\bJV\b|\bteaming\b", blob, re.IGNORECASE):
        return []
    parts = [p.strip() for p in _JV_SPLIT.split(recipient_name or "") if len(p.strip()) > 3]
    out, seen = [], set()
    for p in parts:
        r = resolve_entity(conn, p)
        if r["ticker"] and r["ticker"] not in seen and not r["needs_review"]:
            seen.add(r["ticker"])
            share = None
            m = re.search(re.escape(p) + r"[^.]{0,60}?(\d{1,3})\s*(?:%|percent)", blob, re.IGNORECASE)
            if m:
                try:
                    share = float(m.group(1)) / 100.0
                except Exception:
                    share = None
            out.append({"name": p, "ticker": r["ticker"], "share": share})
    return out if len(out) > 1 else []


